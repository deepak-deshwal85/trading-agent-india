# Application settings (non-secret). Safe to commit.
# Secrets (API keys, Telegram tokens) stay in .env only.
# Load order: app.env first, then .env overrides if the same key is set.

# ── AI models (hybrid: fast for bulk sentiment, deep for stock / market analysis) ──
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_DEEP=claude-sonnet-4-6
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_DEEP=gpt-4o

# When true, --ai also classifies news headlines via the fast model (Haiku / gpt-4o-mini).
# When false, news sentiment uses VADER (--finbert optional) even with --ai.
AI_SENTIMENT_USE_LLM=true
AI_SENTIMENT_BATCH_SIZE=25
AI_SENTIMENT_MAX_TOKENS=1024

# ── Sentiment (local models + ensemble weights) ───────────────────────────────────
SENTIMENT_USE_FINBERT_TONE=true
SENTIMENT_ENSEMBLE_VADER=0.30
SENTIMENT_ENSEMBLE_PROSUS=0.45
SENTIMENT_ENSEMBLE_TONE=0.25
SENTIMENT_RECENCY_HALF_LIFE_HOURS=24
